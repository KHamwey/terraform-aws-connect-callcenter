# Local .terraform directories
**/.terraform/*

# .tfstate files
*.tfstate
*.tfstate.*
*.tfstate.backup

# Crash log files
crash.log
crash.*.log

# Exclude all .tfvars files which are likely to contain sensitive data
*.tfvars
*.tfvars.json
!*.tfvars.example

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Ignore plan output
tfplan
*.tfplan

# OS / editor
.DS_Store
.idea/
.vscode/
*.swp
